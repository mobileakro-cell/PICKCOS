// PICKCOS data model.
// A single generic table stores every collection (supplier, article, exhibition,
// inquiry, matchingRequest, member, setting) as a JSON row. Filtering stays in
// the API layer (dataset is small), so the app code barely changes vs the old
// file store — only persistence moves to Postgres (Supabase).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Entity {
  collection String
  id         String
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@id([collection, id])
  @@index([collection])
}
