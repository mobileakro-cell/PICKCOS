# ── Supabase Postgres (Vercel) ──
# Use the POOLED connection string (port 6543) for the app, and the DIRECT
# string (port 5432) for migrations. Both are in Supabase → Project Settings →
# Database → Connection string (choose "Prisma").
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# ── Admin login (used by /admin) ──
ADMIN_ID="your-admin-id"
ADMIN_PW="a-strong-password"
# Optional second admin
ADMIN2_ID="admin"
ADMIN2_PW="another-strong-password"

# ── Admin session signing (src/lib/auth.ts) ──
# Secret used to HMAC-sign the admin session cookie. Set a long random string in
# production — without it the code falls back to an insecure dev default.
SESSION_SECRET="a-long-random-secret"

# ── Supabase Storage (admin image upload → /api/upload) ──
# Required for the admin panel's image uploads. SUPABASE_URL is the project URL,
# the SERVICE ROLE key is server-only (never expose it to the client), and BUCKET
# is the public storage bucket name (defaults to "image" if omitted).
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="image"
